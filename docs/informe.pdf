(SQL:) Tj
T*
(SELECT) Tj
T*
(    pr.nombre AS producto,) Tj
T*
(    SUM\(dp.cantidad\) AS unidades_vendidas,) Tj
T*
(    ROUND\(SUM\(dp.cantidad * dp.precio_unitario * \(1 - dp.descuento / 100.0\)\), 2\) AS) Tj
T*
(ingresos_netos) Tj
T*
(FROM pedido p) Tj
T*
(JOIN detalle_pedido dp ON dp.id_pedido = p.id_pedido) Tj
T*
(JOIN producto pr ON pr.id_producto = dp.id_producto) Tj
