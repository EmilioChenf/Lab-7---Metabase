/F1 9 Tf
50 780 Td
12 TL
() Tj
T*
(SQL:) Tj
T*
(WITH ventas AS \() Tj
T*
(    SELECT) Tj
T*
(        DATE_TRUNC\('month', p.fecha\)::date AS mes,) Tj
T*
(        SUM\(dp.cantidad * dp.precio_unitario * \(1 - dp.descuento / 100.0\)\) AS ingresos_netos) Tj
T*
(    FROM pedido p) Tj
T*
(    JOIN detalle_pedido dp ON dp.id_pedido = p.id_pedido) Tj
T*
(    WHERE p.estado IN \('completado', 'devuelto'\)) Tj
T*
(    GROUP BY mes) Tj
T*
(\),) Tj
T*
(devoluciones AS \() Tj
T*
(    SELECT) Tj
T*
(        DATE_TRUNC\('month', d.fecha\)::date AS mes,) Tj
T*
(        SUM\(d.monto_reembolso\) AS monto_reembolsado) Tj
T*
(    FROM devolucion d) Tj
T*
(    GROUP BY mes) Tj
T*
(\)) Tj
T*
(SELECT) Tj
T*
(    v.mes,) Tj
T*
(    ROUND\(COALESCE\(d.monto_reembolsado, 0\), 2\) AS monto_reembolsado,) Tj
T*
(    ROUND\(100.0 * COALESCE\(d.monto_reembolsado, 0\) / NULLIF\(v.ingresos_netos, 0\), 2\) AS) Tj
T*
(tasa_devolucion_porcentaje) Tj
T*
(FROM ventas v) Tj
T*
(LEFT JOIN devoluciones d ON d.mes = v.mes) Tj
T*
(ORDER BY v.mes;) Tj
T*
() Tj
T*
() Tj
T*
